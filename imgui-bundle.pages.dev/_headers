# Cloudflare Pages _headers file (copied to _cf_staging/_headers at stage time).
# Syntax: https://developers.cloudflare.com/pages/configuration/headers/
#
# Scope COOP/COEP to /explorer/* only. Site-wide would break the playground,
# which pulls Pyodide from a CDN that doesn't set CORP headers.

/explorer/*
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Embedder-Policy: require-corp

# Emscripten .data bundles are application/octet-stream, which CF does NOT
# auto-compress. Override the Content-Type to application/wasm (which IS on
# CF's compressible list) so the edge applies Brotli/gzip automatically.
# Emscripten loads .data via fetch().arrayBuffer() and ignores Content-Type,
# so this is behaviorally safe.
# Note: Content-Encoding is reserved on CF Pages (user rules are silently
# stripped), which is why we go via Content-Type instead of pre-compressing.
/explorer/*.data
  Content-Type: application/wasm
